# PostgreSQL
POSTGRES_DB=auth-prod
POSTGRES_PORT=54322
POSTGRES_USER=auth-user-prod
POSTGRES_PASSWORD=auth-password-prod

# Migration
MIGRATION_DIR=./migrations
PG_DSN="host=pg port=5432 dbname=${POSTGRES_DB} user=${POSTGRES_USER} password=${POSTGRES_PASSWORD} sslmode=disable"
MIGRATION_DSN=${PG_DSN}

# gRPC
GRPC_HOST=localhost
GRPC_PORT=50052
